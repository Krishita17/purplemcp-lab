# ============================================================================
#  PurpleMCP — environment configuration
#  Copy this file to ".env" and fill in the values you need.
#  ".env" is git-ignored. NEVER commit real keys.
#  You only need keys for the providers you actually want to use.
# ============================================================================

# ---- Local models (Ollama) -------------------------------------------------
# No API key needed. Just have Ollama running (`ollama serve`).
#
# IMPORTANT: pick a model that does *structured tool-calling*, or the agent/chat
# can't actually drive MCP tools. qwen2.5 is the most reliable local default;
# llama3.1 chats fine but often narrates a JSON "call" instead of emitting a real
# one, which makes the Chat Playground look broken.   ollama pull qwen2.5
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5

# ---- Anthropic (Claude) ----------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ---- OpenAI (GPT) ----------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ---- Google (Gemini) -------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ---- OpenRouter (many models behind one key) -------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ---- Default provider used by the CLI when --provider is omitted -----------
# one of: ollama | anthropic | openai | gemini | openrouter
PURPLEMCP_DEFAULT_PROVIDER=ollama

# ============================================================================
#  SERVICE INTEGRATIONS (bring-your-own-key, used by the live-API MCP servers)
#  All optional. Enter them on the AI Models page or here. Real APIs, no mocks.
# ============================================================================
# threat_intel server — VirusTotal URL/domain/file-hash reputation (free key)
VT_API_KEY=
# threat_intel server — AbuseIPDB IP reputation (free key)
ABUSEIPDB_API_KEY=
# web_search server — Tavily live web search (free key)
TAVILY_API_KEY=
# (No key needed for the live_data server: Open-Meteo + CoinGecko are keyless.)

# ============================================================================
#  ATTACK LAB SAFETY SWITCH
#  The intentionally-vulnerable servers under attacks/ refuse to run unless
#  this is set to exactly "i-understand-this-is-a-lab". This is a deliberate
#  speed bump so you never start a vulnerable server by accident.
# ============================================================================
PURPLEMCP_LAB_ENABLED=
